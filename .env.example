# ─── Required ─────────────────────────────────────────────────────────────────
# Federal Reserve Economic Data (FRED) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ─── Optional ─────────────────────────────────────────────────────────────────
# CoinMetrics community tier is used automatically if this is not set.
# COINMETRICS_API_KEY=your_coinmetrics_api_key_here
